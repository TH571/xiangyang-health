# Frontend Environment Variables (Production)
# Copy this file to .env.production and update with your backend server URL

# Backend API Base URL (required for production)
# In production, this should point to your deployed backend server
# Example: https://api.xiangyang.example.com
VITE_API_BASE_URL=

# Backend Environment Variables
# These should be set on your cloud server

# Application Base URL (for generating full image URLs)
# Example: https://api.xiangyang.example.com
APP_BASE_URL=

# Database URL (usually SQLite file path on production server)
DATABASE_URL="file:./dev.db"

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET="change-this-to-a-strong-random-string"

# Allowed CORS origins (comma-separated list of frontend domains)
# Example: https://xiangyang.pages.dev,https://www.xiangyang.example.com
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

# Server Port
PORT=3000

# Node Environment
NODE_ENV=production
